#flags_language_selector {
	clear: both !important;
	float: left !important;
	margin: 6px 0 0 0 !important;
	width: 184px;
	line-height: 18px;
	max-width: 184px;
	text-align: center;
	white-space: nowrap;
	overflow: visible;
}

#flags_language_selector a,
#flags_language_selector img {
	float: none !important;
	display: inline-block;
	vertical-align: middle;
}

#flags_language_selector img {
	width: 20px !important;
	height: auto !important;
	margin: 1px 2px 1px 0 !important;
	box-sizing: border-box;
}

#codex_store_qr {
	clear: both;
	float: left;
	margin: 9px 0 0 0;
	width: 184px !important;
	max-width: 184px !important;
	height: auto;
	max-height: none;
	overflow: visible;
	text-align: center;
}

#codex_store_qr > a:first-child {
	display: block;
	width: 64px;
	margin: 0 auto;
}

#codex_store_qr img {
	display: block;
	width: 64px !important;
	max-width: 64px !important;
	height: 64px !important;
	max-height: 64px !important;
	margin: 0 auto;
	padding: 3px;
	border: 1px solid #333;
	background: #fff;
	box-sizing: border-box;
}

#codex_instagram_row {
	clear: both;
	display: block;
	width: 100%;
	margin-top: 5px;
	text-align: center;
	line-height: 20px;
}

#codex_instagram_link {
	display: inline-flex !important;
	align-items: center;
	justify-content: center;
	gap: 5px;
	margin: 0 auto;
	color: #fff;
	font-family: Arial, Helvetica, sans-serif;
	font-size: 13px;
	font-weight: normal;
	line-height: 20px;
	text-decoration: none;
	text-transform: lowercase;
}

#codex_instagram_link:hover {
	text-decoration: none;
}

#codex_instagram_link .codex_instagram_icon {
	position: relative;
	display: inline-block;
	width: 14px;
	height: 14px;
	border: 1px solid #fff;
	border-radius: 3px;
	box-sizing: border-box;
	flex: 0 0 auto;
}

#codex_instagram_link .codex_instagram_icon:before {
	content: "";
	position: absolute;
	left: 4px;
	top: 4px;
	width: 4px;
	height: 4px;
	border: 1px solid #fff;
	border-radius: 50%;
	box-sizing: border-box;
}

#codex_instagram_link .codex_instagram_icon:after {
	content: "";
	position: absolute;
	right: 2px;
	top: 2px;
	width: 2px;
	height: 2px;
	background: #fff;
	border-radius: 50%;
}

#social_icons {
	bottom: 10px;
	z-index: 10020;
}

#social_icons a {
	display: inline-block;
	vertical-align: bottom;
}

#social_icons a img {
	width: auto;
	height: 20px;
}

#social_icons #search_ico img {
	width: auto;
	height: 20px;
}

#dc-slick-3 .tab {
	font-size: 16px !important;
	line-height: 16px !important;
}

#dc-slick-3 .tab span {
	padding: 10px 12px 10px 32px !important;
	background-position: 10px 50% !important;
}

@media screen and (max-height: 660px) {
	#flags_language_selector {
		width: 176px;
		line-height: 17px;
	}

	#flags_language_selector img {
		width: 19px !important;
		margin-right: 2px !important;
	}

	#codex_store_qr {
		margin-top: 5px;
		width: 176px !important;
		max-width: 176px !important;
	}

	#codex_store_qr img {
		width: 60px !important;
		max-width: 60px !important;
		height: 60px !important;
		max-height: 60px !important;
		padding: 3px;
	}

	#codex_instagram_row {
		margin-top: 4px;
		line-height: 18px;
	}

	#codex_instagram_link {
		font-size: 12px;
		line-height: 18px;
	}

	#social_icons a img,
	#social_icons #search_ico img {
		height: 18px;
	}
}

